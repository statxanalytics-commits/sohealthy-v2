{
  "expo": {
    "name": "sohealthy-v2",
    "slug": "sohealthy-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sohealthyv2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SoHealthy ka nevoj\u00eb p\u00ebr kamer\u00ebn p\u00ebr t\u00eb analizuar ushqimet tuaja.",
        "NSPhotoLibraryUsageDescription": "SoHealthy ka nevoj\u00eb p\u00ebr galerin\u00eb p\u00ebr t\u00eb analizuar fotografit\u00eb e ushqimeve."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single-page",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "name": "SoHealthy",
      "shortName": "SoHealthy",
      "description": "Platforma jote e shendetit dhe wellnessit",
      "themeColor": "#1B3F2F",
      "backgroundColor": "#ECEFE8",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "sq"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SoHealthy ka nevoj\u00eb p\u00ebr galerin\u00eb p\u00ebr t\u00eb analizuar fotografit\u00eb e ushqimeve.",
          "cameraPermission": "SoHealthy ka nevoj\u00eb p\u00ebr kamer\u00ebn p\u00ebr t\u00eb analizuar ushqimet tuaja."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ]
  }
}
